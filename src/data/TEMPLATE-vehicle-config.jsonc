                                    "value": [{ "name": "$", "codename": "usd" }]
                                  },
                                  "value": {
                                    "_comment": "Price amount",
                                    "_type": "NumberElement",
                                    "value": "FILL_IN: number, e.g. 15000"
                                  }
                                }
                              },
                              {
                                "_comment": "OPTIONAL: Dealer-specific price — repeat for each dealer who gets custom pricing",
                                "system": {
                                  "id": "FILL_IN: UUID",
                                  "codename": "FILL_IN",
                                  "type": "price_5737012"
                                },
                                "elements": {
                                  "entity": {
                                    "_comment": "Dealer's email address — matched against logged-in user's email",
                                    "value": "FILL_IN: e.g. 'dealer@fernhay.com'"
