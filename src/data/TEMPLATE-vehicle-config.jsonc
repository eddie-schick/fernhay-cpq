                                  "unit": {
                                    "value": [{ "name": "$", "codename": "usd" }]
                                  },
                                  "value": {
                                    "value": "FILL_IN: dealer-specific price number"
                                  }
                                }
                              }
                            ]
                          },

                          "additional_specifications": {
                            "_comment": "Additional specs — rich text linked items. Each has title + value.",
                            "_type": "RichTextElement (resolved as linked items: ProductSpecifications[])",
                            "_required": false,
                            "linkedItems": [
                              {
                                "system": { "id": "FILL_IN", "type": "product_specifications" },
                                "elements": {
                                  "title": {
                                    "_comment": "Spec label, e.g. 'Input Voltage'",
                                    "value": "FILL_IN"
