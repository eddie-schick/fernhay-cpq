                          "paint_options": {
                            "_comment": "=== PAINT COLORS AVAILABLE FOR THIS OPTION ===",
                            "_comment2": "Only applicable for chassis/upfit options. The selected chassis/upfit determines available paint colors.",
                            "_comment3": "See configurator-page-provider.tsx:358-367 — paintTypeOptions derived from selectedUpfit || selectedChassis",
                            "_type": "LinkedItemsElement<Paint>",
